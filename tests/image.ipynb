   "source": [
    "# 1 pixel plot to not commit a massive b64 string\n",
    "\n",
    "from PIL import Image\n",
    "from IPython.display import display\n",
    "\n",
    "# rgba ensures it doesnt also generate a jpeg\n",
    "img = Image.new(\"RGBA\", (1, 1), (255, 0, 0, 255))\n",
    "\n",
    "display(img)"
   ]
